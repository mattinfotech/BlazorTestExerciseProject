@page "/"
@rendermode InteractiveServer
@using BlazorTestProject.Models
@using Microsoft.AspNetCore.Components.Web

<PageTitle>User Form Demo</PageTitle>
<div class="container">
    <UserForm Model="User"
              SubmitButtonText="Save User"
              IsSubmitting="IsSubmitting"
              OnSubmit="HandleSubmit" />

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="alert alert-success shadow-sm mt-3 mb-0" role="alert">
            @StatusMessage
        </div>
    }
    @if (SubmittedUser is not null)
    {
        <div class="card shadow-sm mt-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="card-title h4 mb-0">Submitted Data</h2>
                    <span class="badge bg-success">Saved</span>
                </div>

                <div class="table-responsive">
                    <table class="table table-borderless align-middle mb-0">
                        <tbody>
                            <tr>
                                <th class="text-muted fw-medium" style="width: 180px;">Name</th>
                                <td>@SubmittedUser.Name</td>
                            </tr>
                            <tr>
                                <th class="text-muted fw-medium">Address</th>
                                <td>@SubmittedUser.Address</td>
                            </tr>
                            <tr>
                                <th class="text-muted fw-medium">Age</th>
                                <td>@SubmittedUser.Age</td>
                            </tr>
                            <tr>
                                <th class="text-muted fw-medium">Email</th>
                                <td class="text-break">@SubmittedUser.Email</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

</div>
